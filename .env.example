# ── rogersense environment (copy to .env, never commit .env) ──

# Server
PORT=3001
SITE_URL=https://rogersense.com          # public origin; used for OAuth redirect + sitemap

# Auth
JWT_SECRET=                              # long random string — sign client JWTs
DEFAULT_ADMIN_EMAIL=admin@rogersense.com # seeded on first boot if no admin exists
DEFAULT_ADMIN_PASSWORD=                  # set a strong one; change after first login

# Cloudflare D1 (database over HTTP REST API)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=                     # token with D1 read/write

# Cloudflare R2 (object storage, S3-compatible)
R2_ACCOUNT_ID=                            # usually same as CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rogersense-files
R2_PUBLIC_URL=                            # e.g. https://static.rogersense.com (optional; for public assets)

# Admin blog image upload: POST /api/admin/upload/image
# Uses sharp (npm dependency) to convert images to WebP. If sharp is unavailable
# in a deployment environment, set CWEBP_BIN to a working cwebp binary.
ADMIN_IMAGE_UPLOAD_MAX_BYTES=10485760      # 10MB
ADMIN_BLOG_IMAGE_PREFIX=products/blog
WEBP_QUALITY=82
CWEBP_BIN=                                # optional, e.g. /usr/bin/cwebp

# Secret-at-rest encryption (AES-256-GCM) for SMTP pass / API keys in settings table
SETTINGS_ENCRYPT_KEY=

# GitHub OAuth (optional — leave blank to disable GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mail fallback (settings table overrides these if configured in admin)
MAIL_FROM=noreply@rogersense.com
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=
